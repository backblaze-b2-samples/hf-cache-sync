# Copy to .env and fill in your values, then load it:
#
#     cp .env.example .env
#     # edit .env
#     export $(grep -v '^#' .env | xargs)
#
# With these set, hf-cache-sync runs without any YAML config.
# Env values override the YAML config when both are present.

# --- Credentials -------------------------------------------------------------
# B2-native (preferred). Both must be set together.
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=

# AWS-style fallback (used if the B2 pair above is incomplete). Useful for
# AWS S3 or any other S3-compatible store.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Storage settings --------------------------------------------------------
# S3-compatible endpoint URL. For Backblaze B2, this is shown on the
# bucket details page (e.g. https://s3.us-east-005.backblazeb2.com).
B2_ENDPOINT=

# Bucket name.
B2_BUCKET=

# Bucket region (e.g. us-east-005, us-west-000).
B2_REGION=
